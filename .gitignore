# Local configuration and secrets
.env
.env.*
!.env.example

# Python environments and generated bytecode
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class

# Tool caches and dependency caches
.cache/**
!.cache/
!.cache/.gitkeep
!.cache/huggingface/
!.cache/huggingface/.gitkeep
!.cache/huggingface/hub/
!.cache/huggingface/hub/.gitkeep
!.cache/huggingface/transformers/
!.cache/huggingface/transformers/.gitkeep
!.cache/torch/
!.cache/torch/.gitkeep
!.cache/pip/
!.cache/pip/.gitkeep
!.cache/nltk/
!.cache/nltk/.gitkeep

# Runtime data: user uploads, transcripts, logs, and temp files
uploads/**
!uploads/
!uploads/.gitkeep
outputs/**
!outputs/
!outputs/.gitkeep
logs/**
!logs/
!logs/.gitkeep
tmp/**
!tmp/
!tmp/.gitkeep

# Local model weights and Hugging Face snapshots
models/asr/**
!models/asr/
!models/asr/.gitkeep
models/align/**
!models/align/
!models/align/.gitkeep
models/diarization/**
!models/diarization/
!models/diarization/.gitkeep

# Common local artifacts
*.log
*.tmp
*.bak
*.swp
.DS_Store
Thumbs.db
